OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Email alerts (SMTP)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=alerts@yourdomain.com
ALERT_EMAIL_TO=support@yourdomain.com

# Security and throttling
CHAT_MAX_MESSAGE_LENGTH=1000
CHAT_RATE_LIMIT_WINDOW_SECONDS=60
CHAT_RATE_LIMIT_MAX_REQUESTS=12
CHAT_TIMEOUT_SECONDS=18

# Workers and retries
IO_WORKERS=4
IO_RETRY_ATTEMPTS=3

# Long memory summarization
SUMMARY_REFRESH_EVERY=12
SUMMARY_CONTEXT_MESSAGES=30
SUMMARY_MODEL=gpt-4o-mini

# Reindex endpoints are restricted to localhost/private network (no API key required)
