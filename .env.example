# =============================================
# STARSANO - Environment Configuration Example
# =============================================
# Copy this file to .env and fill in with your actual values
# NEVER commit .env to version control

# =============================================
# DATABASE
# =============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_postgres_password_here
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=starsano

# =============================================
# BACKEND (Node.js/Express)
# =============================================
# JWT Secret - GENERATE A SECURE RANDOM STRING
# Example: openssl rand -base64 32
JWT_SECRET=your_secure_jwt_secret_here

# Admin credentials - CHANGE THESE IMMEDIATELY AFTER FIRST LOGIN
ADMIN_EMAIL=admin@starsano.com.mx
ADMIN_PASSWORD=your_secure_admin_password_here

# API Secret for batch operations (CSV imports)
API_SECRET_KEY=your_secure_api_secret_key_here

# =============================================
# EMAIL / SMTP
# =============================================
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your_smtp_user@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@starsano.com.mx
ALERT_EMAIL_TO=admin@starsano.com.mx

# =============================================
# OPENAI / LLM
# =============================================
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# =============================================
# FRONTEND
# =============================================
FRONTEND_URL=http://localhost:8080/

# =============================================
# CHATBOT SERVICE
# =============================================
CHAT_MAX_MESSAGE_LENGTH=1000
CHAT_RATE_LIMIT_WINDOW_SECONDS=60
CHAT_RATE_LIMIT_MAX_REQUESTS=12
CHAT_TIMEOUT_SECONDS=60

# Long memory summarization
SUMMARY_REFRESH_EVERY=12
SUMMARY_CONTEXT_MESSAGES=30
SUMMARY_MODEL=gpt-4o-mini

# Conversation retention
CONVERSATION_RETENTION_DAYS=10
CONVERSATION_CLEANUP_INTERVAL_SECONDS=3600

# Workers and retries
IO_WORKERS=4
IO_RETRY_ATTEMPTS=3

# Logging level (DEBUG, INFO, WARNING, ERROR)
CHATBOT_LOG_LEVEL=INFO

# CORS - Restrict to your frontend domain
ALLOWED_ORIGINS=http://localhost:8080,http://starsano.com.mx,https://starsano.com.mx

# =============================================
# SEO ARTICLE WRITER SERVICE
# =============================================
STORE_BASE_URL=http://localhost:8080/#/product/

# =============================================
# OPTIONAL - File Upload
# =============================================
MAX_FILE_SIZE_MB=10
ALLOWED_UPLOAD_EXTENSIONS=jpg,jpeg,png,gif,webp
